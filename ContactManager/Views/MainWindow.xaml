<Window x:Class="ContactManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="📇 Contact Manager — PRN212"
        Height="680" Width="1120"
        MinHeight="580" MinWidth="900"
        FontFamily="Segoe UI">

    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFDE68A" Offset="0"/>
            <GradientStop Color="#FFFCD34D" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>

        <!-- CARD -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="#FDE68A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.13"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- FIELD LABEL -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#78350F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>

        <!-- TEXTBOX -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#FFFEFCE8"/>
            <Setter Property="BorderBrush" Value="#FCD34D"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#F59E0B"/>
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#F59E0B" BlurRadius="10" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#F5F5F5"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#DDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- BUTTON -->
        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                CornerRadius="10"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.70"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.40"/>
                                <Setter TargetName="bd" Property="Background" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ===== ROOT: Header + Content + StatusBar ===== -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Padding="16,10" Margin="12,12,12,6"
                Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="📇 Contact Manager"
                               FontSize="20" FontWeight="Bold" Foreground="#92400E"/>
                    <TextBlock Text="PRN212 — Nhóm: Tuệ Minh · Hồng Loan · Anh Khôi · Hữu Trí"
                               FontSize="11" Foreground="#B45309" Margin="2,1,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="MVVM  ·  EF Core  ·  SQL Server"
                               FontSize="11" Foreground="#D97706" FontStyle="Italic"/>
                    <TextBlock Text="{Binding TotalContacts, StringFormat='Tổng cộng: {0} liên hệ'}"
                               FontSize="11" Foreground="#92400E" HorizontalAlignment="Right" Margin="0,2,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1" Margin="12,0,12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" MinWidth="420"/>
                <ColumnDefinition Width="4*" MinWidth="320"/>
            </Grid.ColumnDefinitions>

            <!-- =============================== -->
            <!-- LEFT — Danh sách liên hệ        -->
            <!-- =============================== -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search box -->
                <Border Grid.Row="0" Style="{StaticResource CardStyle}"
                        Padding="12,8" Margin="0,0,0,8">
                    <Grid>
                        <TextBox x:Name="txtSearch"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Margin="0"
                                 FontSize="14"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Text="🔍  Tìm kiếm theo tên hoặc số điện thoại..."
                                   Foreground="#9CA3AF" FontSize="13"
                                   Margin="10,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=txtSearch}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- DataGrid -->
                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="10">
                    <DataGrid x:Name="dgContacts"
                              AutoGenerateColumns="False"
                              ItemsSource="{Binding ContactList}"
                              SelectedItem="{Binding SelectedContact}"
                              RowHeight="42"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              Background="Transparent"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              SelectionMode="Single">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#FEF3C7"/>
                                <Setter Property="Foreground" Value="#92400E"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="10,9"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridRow">
                                            <Border x:Name="bd" CornerRadius="8"
                                                    Background="{TemplateBinding Background}">
                                                <DataGridCellsPresenter/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#FEF3C7"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#FDE68A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.RowStyle>

                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="Transparent">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Họ và Tên"       Binding="{Binding FullName}"    Width="2.2*"/>
                            <DataGridTextColumn Header="Số điện thoại"   Binding="{Binding PhoneNumber}" Width="1.5*"/>
                            <DataGridTextColumn Header="Email"            Binding="{Binding Email}"       Width="2.2*"/>
                            <DataGridTextColumn Header="Địa chỉ"          Binding="{Binding Address}"     Width="1.5*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- =============================== -->
            <!-- RIGHT — Form chi tiết / edit    -->
            <!-- =============================== -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="20,16">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>

                        <!-- Title -->
                        <TextBlock Text="✨ Chi tiết liên hệ"
                                   FontSize="17" FontWeight="Bold"
                                   Foreground="#92400E" Margin="0,0,0,10"/>

                        <!-- Hint -->
                        <Border CornerRadius="8" Background="#FEF9C3"
                                BorderBrush="#FDE68A" BorderThickness="1"
                                Padding="10,7" Margin="0,0,0,12">
                            <TextBlock FontSize="11" Foreground="#92400E" TextWrapping="Wrap"
                                       Text="👆 Chọn một liên hệ để xem / sửa thông tin.&#10;Bấm ➕ Thêm mới để điền thông tin liên hệ mới."/>
                        </Border>

                        <!-- ─── Fields ─── -->
                        <TextBlock Text="Họ và Tên  *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SelectedContact.FullName, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Số điện thoại  *" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SelectedContact.PhoneNumber, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Email" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SelectedContact.Email, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Địa chỉ" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SelectedContact.Address, UpdateSourceTrigger=PropertyChanged}"/>

                        <TextBlock Text="Danh mục (VD: Bạn bè, Gia đình...)" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding SelectedContact.Category, UpdateSourceTrigger=PropertyChanged}"
                                 Margin="0,0,0,12"/>

                        <Separator Background="#FDE68A" Margin="0,4,0,10"/>

                        <!-- ─── Buttons ─── -->

                        <!-- Row 1: Thêm mới + Lưu thay đổi -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="➕  Thêm mới"
                                    Background="#FBBF24"
                                    Command="{Binding AddCommand}"/>
                            <Button Grid.Column="1"
                                    Content="💾  Lưu thay đổi"
                                    Background="#10B981"
                                    Command="{Binding SaveCommand}"/>
                        </Grid>

                        <!-- Row 2: Xóa + Lịch sử gọi -->
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0"
                                    Content="🗑  Xóa liên hệ"
                                    Background="#EF4444"
                                    Command="{Binding DeleteCommand}"/>
                            <Button Grid.Column="1"
                                    Content="📞  Lịch sử gọi"
                                    Background="#3B82F6"
                                    Click="OpenCallHistory_Click"/>
                        </Grid>

                        <!-- Row 3: Hủy (chỉ hiện khi đang thêm mới) -->
                        <Button Content="🚫  Hủy thao tác thêm mới"
                                Background="#6B7280"
                                Margin="3,2,3,0"
                                Command="{Binding CancelCommand}"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ===== STATUS BAR ===== -->
        <Border Grid.Row="2" Margin="12,0,12,10"
                Background="#78350F" CornerRadius="8" Padding="14,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           FontSize="12" Foreground="White"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="PRN212 — Contact Manager v1.0"
                           FontSize="11" Foreground="#FDE68A"
                           FontStyle="Italic" VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</Window>
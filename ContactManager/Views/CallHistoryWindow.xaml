<Window x:Class="ContactManager.Views.CallHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ContactManager.Views"
        mc:Ignorable="d"
         Title="📞 Call History"
        Height="500" Width="800"
        FontFamily="Segoe UI">

    <!-- ===== BACKGROUND GIỐNG MAIN ===== -->
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFDE68A" Offset="0"/>
            <GradientStop Color="#FFFCD34D" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <!-- ===== STYLE GIỐNG MAIN ===== -->
    <Window.Resources>

        <!-- CARD -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="BorderBrush" Value="#FDE68A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.15"/>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ===== LAYOUT ===== -->
    <Grid Margin="12">

        <Border Style="{StaticResource CardStyle}">

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="📞 Call History"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#92400E"
                           Margin="0,0,0,15"/>

                <!-- DATAGRID -->
                <DataGrid ItemsSource="{Binding CallLogs}"
                          AutoGenerateColumns="False"
                          RowHeight="40"
                          GridLinesVisibility="None"
                          BorderThickness="0"
                          Background="Transparent">

                    <!-- ROW STYLE -->
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="Background" Value="White"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridRow">
                                        <Border x:Name="bd"
                                                CornerRadius="8"
                                                Background="{TemplateBinding Background}">
                                            <DataGridCellsPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#FEF3C7"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="bd" Property="Background" Value="#FDE68A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </DataGrid.RowStyle>

                    <!-- COLUMNS -->
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="*"/>
                        <DataGridTextColumn Header="Time"
                            Binding="{Binding CallTime, StringFormat=dd/MM/yyyy HH:mm}"
                            Width="*"/>
                    </DataGrid.Columns>

                </DataGrid>

            </StackPanel>
        </Border>

    </Grid>
</Window>